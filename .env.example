# .env.example
# LLM 配置
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=sk-xxx
LLM_MODEL=gpt-4o

# 交易所配置
OKX_API_KEY=xxx
OKX_API_SECRET=xxx
OKX_PASSPHRASE=xxx

# 通知配置
LARK_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# 邮箱配置
SMTP_SERVER=smtp.qq.com
SMTP_PORT=587
FROM_EMAIL=your-email@gmail.com
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_RECIPIENT=recipient@example.com
USE_TLS=true

# 策略配置
# volatility short-selling strategy
VOLATILITY_PRICE_CHANGE_THRESHOLD=5.0
VOLATILITY_VOLATILITY_THRESHOLD=0.0
VOLATILITY_MIN_CANDLES=2
VOLATILITY_BAR=1H
VOLATILITY_LIMIT=8
VOLATILITY_MAX_COINS_TO_CHECK=0

# 扫描间隔配置（秒）
SCAN_INTERVAL_SECS=1800

